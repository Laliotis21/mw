# ---- LLM / Research ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxx

# ---- Broker (paper / sandbox) ----
# Alpaca paper-trading keys (https://app.alpaca.markets/paper/dashboard/overview)
ALPACA_API_KEY=PKxxxxxxxxxxxxxxxx
ALPACA_SECRET_KEY=xxxxxxxxxxxxxxxx
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ---- Risk / Capital ----
STARTING_CAPITAL=1000
MAX_RISK_PCT=0.02          # 2% hard cap per trade -> $20 on $1000
DAILY_MAX_LOSS_PCT=0.05    # circuit breaker: stop trading after -5% day

# ---- Discovery (--discover) ----
SCAN_PER_SOURCE=10         # movers pulled per source (per screener / coin page)
MAX_CANDIDATES=5           # top-N shortlisted ideas the desk actually trades

# ---- Models (override if deprecated) ----
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
PERPLEXITY_MODEL=sonar          # sonar-medium deprecated; sonar / sonar-pro current

# ---- Provider switches (test agents for FREE, no paid keys) ----
# LLM_PROVIDER:    anthropic (Claude, needs key) | ollama (local, free)
# RESEARCH_SOURCE: perplexity (paid)            | mock (free canned data)
LLM_PROVIDER=ollama
RESEARCH_SOURCE=mock
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
