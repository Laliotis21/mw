# ---- LLM / Research ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxx

# ---- Broker (paper / sandbox) ----
# Alpaca paper-trading keys (https://app.alpaca.markets/paper/dashboard/overview)
ALPACA_API_KEY=PKxxxxxxxxxxxxxxxx
ALPACA_SECRET_KEY=xxxxxxxxxxxxxxxx
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Binance crypto paper trading. Keys from https://testnet.binance.vision
# (log in with GitHub -> Generate HMAC_SHA256 Key). Testnet = fake funds.
# Set FILL_SOURCE=binance to route crypto BUYs to real Binance orders.
BINANCE_API_KEY=xxxxxxxxxxxxxxxx
BINANCE_SECRET_KEY=xxxxxxxxxxxxxxxx
BINANCE_TESTNET=true                        # false = live Binance (real money)
# BINANCE_BASE_URL=https://testnet.binance.vision   # auto-set from BINANCE_TESTNET

# ---- Risk / Capital ----
STARTING_CAPITAL=1000
MAX_RISK_PCT=0.02          # 2% of CURRENT equity per trade (compounds: $20 @ $1000, $30 @ $1500)
DAILY_MAX_LOSS_PCT=0.05    # circuit breaker: stop trading after -5% day
EXIT_STYLE=be_partial      # be_partial = half off at +1R + breakeven stop (backtests better); target = fixed 2R

# ---- Discovery (--discover) ----
SCAN_PER_SOURCE=10         # movers pulled per source (per screener / coin page)
MAX_CANDIDATES=5           # top-N shortlisted ideas the desk actually trades

# ---- Models (override if deprecated) ----
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
PERPLEXITY_MODEL=sonar          # sonar-medium deprecated; sonar / sonar-pro current

# ---- Provider switches (test agents for FREE, no paid keys) ----
# LLM_PROVIDER:    anthropic (Claude, needs key) | ollama (local, free)
# RESEARCH_SOURCE: perplexity (paid)            | mock (free canned data)
LLM_PROVIDER=ollama
RESEARCH_SOURCE=mock
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434

# FILL_SOURCE: how paper fills resolve.
#   yfinance (real bars, local sim) | coinflip (random)
#   binance  (real crypto orders) | alpaca (real stock orders)
#   live     (route per asset: crypto->Binance, stocks->Alpaca)
FILL_SOURCE=yfinance
